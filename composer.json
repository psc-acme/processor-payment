{
    "name": "psc-acme/processor-payment",
    "description": "Package processor-payment for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ProcessorPayment\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "psr/container": "^2.0",
        "symfony/string": "^7.0",
        "symfony/console": "^7.0",
        "psr/event-dispatcher": "^1.0"
    },
    "require-dev": {
        "rector/rector": "^1.0",
        "infection/infection": "^0.27",
        "mockery/mockery": "^1.6"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}